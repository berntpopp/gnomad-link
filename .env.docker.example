# Copy to .env.docker and customize before Docker/NPM deployments.

# gnomAD upstream API.
GNOMAD_API_URL=https://gnomad.broadinstitute.org/api

# Hosted REST + MCP HTTP service.
MCP_TRANSPORT=unified
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Runtime behavior.
LOG_LEVEL=INFO
MCP_LOG_LEVEL=INFO
STDIO_LOG_LEVEL=WARNING
CACHE_SIZE=1024
CACHE_TTL_MINUTES=60
CORS_ORIGINS=*
ENABLE_SWAGGER=true
ENABLE_MONITORING=true
GRACEFUL_SHUTDOWN_TIMEOUT=30
MAX_PAGE_SIZE=100

# External Docker network used by docker/docker-compose.npm.yml.
NPM_NETWORK_NAME=npm_network
